{
  "name": "Watchlist",
  "type": "object",
  "properties": {
    "symbol": {
      "type": "string",
      "description": "Crypto symbol (e.g., X:BTCUSD)"
    },
    "name": {
      "type": "string",
      "description": "Display name"
    },
